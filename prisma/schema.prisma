datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  ADMIN
  DELIVERY
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  phone        String
  address      String
  pincode      String
  role         Role      @default(CUSTOMER)
  passwordHash String
  isActive     Boolean   @default(true)
  firstLogin   Boolean   @default(true)
  createdAt    DateTime  @default(now())

  // Relations
  orders         Order[]       @relation("CustomerOrders")
  assignedOrders Order[]       @relation("DeliveryOrders")
  payments       Payment[]
  notifications  Notification[]
  deliveryLogs   DeliveryLog[]
}

model Product {
  id                String      @id @default(uuid())
  name              String
  size              String      // e.g. "500ml", "1L", "5L", "20L"
  pricePerUnit      Float
  stock             Int         @default(0)
  lowStockThreshold Int         @default(10)
  isAvailable       Boolean     @default(true)
  orderItems        OrderItem[]
}

model Order {
  id                String      @id @default(uuid())
  userId            String
  user              User        @relation("CustomerOrders", fields: [userId], references: [id])
  deliveryPartnerId String?
  deliveryPartner   User?       @relation("DeliveryOrders", fields: [deliveryPartnerId], references: [id])
  status            OrderStatus @default(PENDING)
  deliveryTimeSlot  String      // e.g. "08:00 AM - 12:00 PM"
  deliveryAddress   String
  deliveryPincode   String
  isScheduled       Boolean     @default(false)
  scheduleFrequency String?     // e.g. "WEEKLY", "BIWEEKLY", "MONTHLY"
  qrCode            String?     @unique
  createdAt         DateTime    @default(now())
  deliveredAt       DateTime?

  // Relations
  orderItems   OrderItem[]
  payments     Payment[]
  deliveryLogs DeliveryLog[]
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Float
}

model Payment {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Float
  status    PaymentStatus @default(UNPAID)
  paidAt    DateTime?
  method    String?       // CASH, BANK_TRANSFER
  note      String?
  createdAt DateTime      @default(now())
}

model DeliveryLog {
  id                String   @id @default(uuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  scannedAt         DateTime @default(now())
  deliveryPartnerId String
  deliveryPartner   User     @relation(fields: [deliveryPartnerId], references: [id])
  location          String?
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
